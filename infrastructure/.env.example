# Vorlage für /opt/knoedelstube/mail.env auf dem Hetzner-Server.
# Wichtig: Auf dem Server muss die Datei mail.env heißen (NICHT .env), sonst
# behandelt Docker Compose sie zusätzlich als Projekt-Interpolation-Datei und
# stolpert über $-Zeichen im SMTP-Passwort.
# Diese Datei NICHT mit echten Credentials in Git committen.

# --- Strato SMTP ---
# Hinweis: Hetzner Cloud blockiert standardmäßig Outbound auf Port 25 und 465.
# Wir verwenden daher Port 587 + STARTTLS (SMTP_SECURE=false).
SMTP_HOST=smtp.strato.de
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=kontakt@hefangelist.de
SMTP_PASS=<dein-strato-postfach-passwort>

# --- Mail-Versand ---
# MAIL_FROM muss zur SMTP-Authentifizierung passen (Strato-Pflicht).
MAIL_FROM="Knödelstube Webformular <kontakt@hefangelist.de>"
MAIL_TO=info@knoedelstube.de

# --- Sicherheit ---
# Mehrere Origins kommasepariert (kein Leerzeichen nötig).
# Testphase: nur die Subdomain. Produktiv: beide Domains.
ALLOWED_ORIGIN=https://knoedelstube.hefangelist.de,https://knoedelstube.de,https://www.knoedelstube.de
RATE_LIMIT_PER_HOUR=5

# --- Service ---
PORT=3000

# --- Image-Tag (vom GitHub-Workflow auf Commit-SHA gesetzt; manuelle Werte als Fallback) ---
IMAGE_TAG=latest
